# Optional: override defaults for dataset and branch.
# Used when building the app (local dev or CI). Not required for upload token
# (token is entered in the "Add a hold" dialog or stored in browser localStorage).

# For Hugging Face OAuth
VITE_HF_OAUTH_CLIENT_ID=your_client_id_here

# Hugging Face dataset repo used for the registry and uploads (default: setrsoft/climbing-holds)
VITE_HF_DATASET_REPO_ID=setrsoft/climbing-holds

# Branch / revision (default: main)
VITE_HF_REVISION=main

# Repo used for anonymous contributions (default: eberling1/climbingholds-anonymous-contributions)
VITE_HF_ANONYMOUS_REPO_ID=eberling1/climbingholds-anonymous-contributions

# Backend endpoint for anonymous hold contributions. The HF token stays server-side.
# Leave empty (or unset) to disable the "Publish anonymously" feature.
# VITE_ANONYMOUS_UPLOAD_URL=https://<your-space>.hf.space/contributions/anonymous

# Base path for the app when deployed under a subpath (e.g. GitHub Pages).
# Example: /holds-dataset-hub/
VITE_BASE_PATH=/holds-dataset-hub/

# Vote webhook URL (default: /vote on same-origin). For a Hugging Face Space backend,
# set the full URL, e.g. https://setrsoft-climbing-holds-dataset-indexer.hf.space/webhooks/vote
# VITE_VOTE_WEBHOOK_URL=https://<YOUR-SPACE>.hf.space/webhooks/vote

# Secret sent as X-Webhook-Secret when calling the vote webhook. Required if the backend validates it.
# Warning: this value is embedded in the frontend bundle.
# VITE_VOTE_WEBHOOK_SECRET=your_webhook_secret
