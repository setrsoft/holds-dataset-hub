# Optional: override defaults for dataset and branch.
# Used when building the app (local dev or CI). Not required for upload token
# (token is entered in the "Add a hold" dialog or stored in browser localStorage).

# Hugging Face dataset repo used for the registry and uploads (default: setrsoft/climbing-holds)
VITE_HF_DATASET_REPO_ID=setrsoft/climbing-holds

# Branch / revision (default: main)
VITE_HF_REVISION=main

# Repo used for anonymous contributions (default: eberling1/climbingholds-anonymous-contributions)
VITE_HF_ANONYMOUS_REPO_ID=eberling1/climbingholds-anonymous-contributions

# Token used to push anonymous contributions to the repo above (e.g. your private repo).
# If set, users can choose "Publish anonymously" without entering their own token.
# Warning: this value is embedded in the frontend bundle; prefer a repo with limited exposure or use a backend for sensitive use.
# VITE_HF_ANONYMOUS_TOKEN=hf_xxxx

# Base path for the app when deployed under a subpath (e.g. GitHub Pages).
# Example: /holds-dataset-hub/
VITE_BASE_PATH=/holds-dataset-hub/
